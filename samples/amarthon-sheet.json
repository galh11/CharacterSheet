    {
      "id": "7eee9b1d-a96c-405d-a3d6-82b38a6ee539",
      "title": "Attacks",
      "description": "",
      "accent": "#f59e0b",
      "kind": "actions",
      "scale": 1,
      "fields": [
        {
          "id": "9d832676-fc41-45b8-ab08-4b18fcfffd82",
          "label": "Quarterstaff",
          "type": "text",
          "value": "",
          "description": "Strength-based two-handed 1d8. Toggle Shillelagh to use your spellcasting ability (WIS) and a 1d8 die instead. Topple mastery: on a hit the target makes a CON save (DC {8 + proficiency + wis_mod}) or falls Prone.",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d6+{str_mod}",
            "type": "bludgeoning",
            "range": "5 ft"
          },
          "toggles": [
            {
              "id": "971c917c-0e48-45b3-be1c-289e3d44c06c",
              "label": "Shillelagh",
              "active": false,
              "hitMode": "replace",
              "hit": "+{wis_mod + proficiency}",
              "parts": [
                {
                  "mode": "replace",
                  "damage": "1d8+{wis_mod}",
                  "type": "bludgeoning"
                }
              ],
              "setType": "",
              "description": "Cast Shillelagh: the staff uses your spellcasting ability (WIS) and deals 1d8."
            },
            {
              "id": "ad88b72f-1220-47ba-9b28-32d4cb15561a",
              "label": "Primal Strike",
              "active": false,
              "hitMode": "add",
              "hit": "",
              "parts": [
                {
                  "mode": "add",
                  "damage": "1d8",
                  "type": "bludgeoning"
                }
              ],
              "setType": "",
              "description": "Circle of the Moon: once per turn add 1d8 of the weapon’s damage type on a hit."
            }
          ]
        },
        {
          "id": "eb0bed8b-2e79-417a-9f75-77d51959d2fc",
          "label": "Longbow",
          "type": "text",
          "value": "",
          "description": "Slow mastery: on a hit, reduce the target’s Speed by 10 ft until your next turn.",
          "meta": {
            "hit": "+{dex_mod + proficiency}",
            "damage": "1d8+{dex_mod}",
            "type": "piercing",
            "range": "150/600"
          }
        },
        {
          "id": "86ea2f0f-8f75-45b6-a529-f530dc601bf9",
          "label": "Poison Spray (cantrip)",
          "type": "text",
          "value": "",
          "description": "Ranged 10 ft. Target makes a CON save vs your spell DC {8 + proficiency + wis_mod}; on a fail it takes the damage. Damage dice scale with your cantrip tier (from level).",
          "meta": {
            "damage": "{1 + floor((level + 1) / 6)}d12",
            "type": "poison",
            "range": "10 ft"
          }
        }
      ],
