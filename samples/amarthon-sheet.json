    {
      "id": "c96989c7-c1ca-4465-9cb2-2c2b226a9ae6",
      "title": "Features & Traits",
      "description": "",
      "accent": "#8b5cf6",
      "kind": "actions",
      "scale": 1,
      "fields": [
        {
          "id": "61e91696-43e8-437c-98a5-7878e16a7a56",
          "label": "Druidic",
          "type": "text",
          "value": "",
          "description": "You know Druidic, the secret language of druids, and can leave hidden messages. You automatically spot such messages and can decipher them."
        },
        {
          "id": "05a11f9d-f5e2-46ea-a8f7-932271b2561e",
          "label": "Primal Order — Magician",
          "type": "text",
          "value": "",
          "description": "You know one extra Druid cantrip (Poison Spray). Add your WIS mod (min +1) to your Intelligence (Arcana or Nature) checks.",
          "effects": [
            {
              "target": "arcana",
              "op": "add",
              "value": "wis_mod"
            },
            {
              "target": "nature",
              "op": "add",
              "value": "wis_mod"
            }
          ]
        },
        {
          "id": "c211429e-4702-4be9-a4fe-b09d1d8bc829",
          "label": "Wild Shape (3/rest)",
          "type": "text",
          "value": "",
          "description": "Bonus Action: transform into a known Beast form (from level 8, max CR 1 and you may take a form with a Fly Speed). Lasts hours = half your level. 3 uses at level 8; regain one on a Short Rest, all on a Long Rest. Assuming a form grants Temp HP = your Druid level."
        },
        {
          "id": "055a6a55-1892-4d60-ac8a-e9fd930c82b1",
          "label": "Wild Companion",
          "type": "text",
          "value": "",
          "description": "Magic action: expend a spell slot or a Wild Shape use to cast Find Familiar without Materials; the familiar is Fey and lasts until your next Long Rest."
        },
        {
          "id": "21185ec4-176b-4fa2-b37c-d512f173123d",
          "label": "Circle Forms (Circle of the Moon)",
          "type": "text",
          "value": "",
          "description": "While in Wild Shape your AC becomes 13 + WIS mod (17) if higher than the beast’s, and you gain Temp HP = 3 × your Druid level (24) in place of the normal Wild Shape Temp HP."
        },
        {
          "id": "2b3ed1a4-3c5b-4f88-903a-108c05d91b85",
          "label": "Wild Resurgence",
          "type": "text",
          "value": "",
          "description": "Once per turn, if you have no Wild Shape uses left, expend a spell slot to regain one (no action). Also, once per Long Rest, expend a Wild Shape use to regain a level 1 spell slot."
        },
        {
          "id": "d4750f81-8765-40a9-9e4c-0cd373aaef19",
          "label": "Improved Circle Forms (L6)",
          "type": "text",
          "value": "",
          "description": "While in Wild Shape: your attacks can deal Radiant instead of their normal type (Lunar Radiance), and you add your WIS mod to your Constitution saving throws — toggle the “Wild Shaped” state to fold the CON-save bonus in."
        },
        {
          "id": "b50df458-93d5-4504-9064-b9faf87703da",
          "label": "Elemental Fury — Primal Strike",
          "type": "text",
          "value": "",
          "description": "Once on each of your turns when you hit with an attack roll (including in Wild Shape), deal an extra 1d8 of Cold, Fire, Lightning, or Thunder (choose on hit). Add it via the Primal Strike toggle on the Quarterstaff."
        },
        {
          "id": "d51b1f0a-101b-44d4-96b2-77e7e803b8d8",
          "label": "Spellcasting",
          "type": "text",
          "value": "",
          "description": "Wisdom-based druid casting. Prepare spells from the whole Druid list; swap after a Long Rest. Save DC 15, spell attack +7."
        },
        {
          "id": "1fef234a-bbd5-4c18-91f5-3c313cfb6fc9",
          "label": "War Caster (feat)",
          "type": "text",
          "value": "",
          "description": "Advantage on CON saves to maintain Concentration; cast somatic spells with hands full; cast a spell (1 action, single target) as an opportunity attack."
        },
        {
          "id": "a09afbe3-90d1-41c7-8718-cd949d8d5449",
          "label": "Magic Initiate — Wizard (feat)",
          "type": "text",
          "value": "",
          "description": "Two wizard cantrips (Minor Illusion, Booming Blade) and a level 1 wizard spell (Shield) you can cast free 1/Long Rest or with slots."
        },
        {
          "id": "81f180b2-a292-4c26-bffa-109b6f445043",
          "label": "Fey Touched (feat)",
          "type": "text",
          "value": "",
          "description": "+1 WIS; you always have Misty Step and Silvery Barbs prepared and can cast each once per Long Rest without a slot (WIS-based)."
        }
      ],
      "layout": {
        "x": 24,
