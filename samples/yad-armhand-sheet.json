        {
          "id": "b2af1eb0-0f81-4c0b-bdc0-defbdec8a645",
          "label": "Unarmed Strike",
          "type": "text",
          "value": "",
          "description": "Fisticuffs die d10. Moxie-Fueled Fists: may deal Force instead. Heavy Hitter: also Grapple or Shove on a hit. Hill’s Tumble: knock a Large-or-smaller target Prone (3/Long).",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod}",
            "type": "bludgeoning",
            "range": "5 ft"
          }
        },
        {
          "id": "15efdc20-1194-4a9f-9960-855868320caf",
          "label": "Flame Tongue Handaxe",
          "type": "text",
          "value": "",
          "description": "Uses the d10 fisticuffs die. Ignite as a Bonus Action (toggle “Flame Tongue” in Conditions) to add 2d6 fire.",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod}",
            "type": "slashing",
            "extra": "2d6",
            "extraType": "fire",
            "extraWhen": "flame_tongue",
            "range": "20/60"
          }
        },
        {
          "id": "b0e35367-0512-4b24-bbb3-ddbdeb3555c2",
          "label": "Javelin",
          "type": "text",
          "value": "",
          "description": "Thrown. Slow mastery: reduce target Speed by 10 ft.",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod}",
            "type": "piercing",
            "range": "30/120"
          }
        },
        {
          "id": "d757ab30-69c7-4c13-976c-68e39a7501c3",
          "label": "Compression Lock",
          "type": "text",
          "value": "",
          "description": "Start of your turn: each creature you have Grappled takes this Bludgeoning damage.",
          "meta": {
            "damage": "1d10+{str_mod}",
            "type": "bludgeoning"
          }
        }
      ],
      "layout": {
        "x": 24,
        "y": 442,
        "w": 300,
        "h": 392
      }
