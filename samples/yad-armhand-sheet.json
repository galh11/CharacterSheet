      "fields": [
        {
          "id": "0569c36c-a952-449a-a274-3462f1a2de6e",
          "label": "Fisticuffs",
          "type": "text",
          "value": "",
          "description": "Unarmed/Pugilist-weapon damage die is d10; bonus-action Unarmed Strike. Improved Improvisation: improvised weapons count as having the Sap mastery for you (on a hit, the target has Disadvantage on its next attack before your next turn). You have no other weapon masteries."
        },
        {
          "id": "665cdacb-1035-4181-a2ea-57088c67dcb0",
          "label": "Iron Chin",
          "type": "text",
          "value": "",
          "description": "Base AC = 12 + CON mod while in Light or no armor and no shield."
        },
        {
          "id": "6d13abc0-b0ed-4415-8c99-624e0841f500",
          "label": "Heavy Hitter",
          "type": "text",
          "value": "",
          "description": "On an Unarmed Strike hit: deal Damage AND your choice of Grapple or Shove."
        },
        {
          "id": "7881d2dc-9923-4262-8eaf-1e9de7a26214",
          "label": "Extra Attack",
