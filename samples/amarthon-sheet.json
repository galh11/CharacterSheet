    {
      "id": "3e868ab3-6dc7-4436-acfd-6e27e43f99da",
      "title": "Attacks",
      "description": "",
      "accent": "#f59e0b",
      "kind": "actions",
      "scale": 1,
      "fields": [
        {
          "id": "67b10ead-5730-4ae4-a5c6-11fe0481cf96",
          "label": "Quarterstaff",
          "type": "text",
          "value": "",
          "description": "Strength-based two-handed 1d8. Toggle Shillelagh to use your spellcasting ability (WIS) and a 1d8 die instead. Topple mastery: on a hit the target makes a CON save (DC {8 + proficiency + wis_mod}) or falls Prone.",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d6+{str_mod}",
            "type": "bludgeoning",
            "range": "5 ft"
          },
          "toggles": [
            {
              "id": "da063e65-38de-4680-b5c5-317c3397452b",
              "label": "Shillelagh",
              "active": false,
              "hitMode": "replace",
              "hit": "+{wis_mod + proficiency}",
              "parts": [
                {
                  "mode": "replace",
                  "damage": "1d8+{wis_mod}",
                  "type": "bludgeoning"
                }
              ],
              "setType": "",
              "description": "Cast Shillelagh: the staff uses your spellcasting ability (WIS) and deals 1d8."
            },
            {
              "id": "e0ae42ba-82dc-41d2-a9e0-1733dfc725b4",
              "label": "Primal Strike",
              "active": false,
              "hitMode": "add",
              "hit": "",
              "parts": [
                {
                  "mode": "add",
                  "damage": "1d8",
                  "type": "bludgeoning"
                }
              ],
              "setType": "",
              "description": "Circle of the Moon: once per turn add 1d8 of the weapon’s damage type on a hit."
            }
          ]
        },
        {
          "id": "f3df9778-59e0-4242-8915-4c3095fb27f9",
          "label": "Longbow",
          "type": "text",
          "value": "",
          "description": "Slow mastery: on a hit, reduce the target’s Speed by 10 ft until your next turn.",
          "meta": {
            "hit": "+{dex_mod + proficiency}",
            "damage": "1d8+{dex_mod}",
            "type": "piercing",
            "range": "150/600"
          }
        },
        {
          "id": "8f0974f4-1f6f-41a4-a155-4dbd3fe5ef09",
          "label": "Poison Spray (cantrip)",
          "type": "text",
          "value": "",
          "description": "Ranged 10 ft. Target makes a CON save vs your spell DC {8 + proficiency + wis_mod}; on a fail it takes the damage. Scales with level (2d12 at level 8).",
          "meta": {
            "damage": "2d12",
            "type": "poison",
            "range": "10 ft"
          }
        }
      ],
