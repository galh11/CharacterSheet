    {
      "id": "5fad1048-2332-4ceb-b601-130247277766",
      "title": "Features & Traits",
      "description": "",
      "accent": "#8b5cf6",
      "kind": "actions",
      "scale": 1,
      "fields": [
        {
          "id": "b821d409-c2e5-4e29-9cdc-1d1286848968",
          "label": "Druidic",
          "type": "text",
          "value": "",
          "description": "You know Druidic, the secret language of druids, and can leave hidden messages. You automatically spot such messages and can decipher them."
        },
        {
          "id": "14a5e7af-6e5d-4cd3-a471-6a2d907d1ef8",
          "label": "Primal Order — Magician",
          "type": "text",
          "value": "",
          "description": "You know one extra Druid cantrip (Poison Spray). Add your WIS mod (min +1) to your Intelligence (Arcana or Nature) checks.",
          "effects": [
            {
              "target": "arcana",
              "op": "add",
              "value": "wis_mod"
            },
            {
              "target": "nature",
              "op": "add",
              "value": "wis_mod"
            }
          ]
        },
        {
          "id": "0ddf85b6-ad9c-46bf-8ae5-b4092433a137",
          "label": "Wild Shape (3/rest)",
          "type": "text",
          "value": "",
          "description": "Bonus Action: transform into a known Beast form (max CR 1, no Fly Speed until — from level 8 you may take a form with a Fly Speed). Lasts hours = half your level. 3 uses at level 8; regain one on a Short Rest, all on a Long Rest."
        },
        {
          "id": "046b07e0-709c-4e54-88ae-0865b98b8077",
          "label": "Wild Companion",
          "type": "text",
          "value": "",
          "description": "Magic action: expend a spell slot or a Wild Shape use to cast Find Familiar without Materials; the familiar is Fey and lasts until your next Long Rest."
        },
        {
          "id": "0eb5f8b0-86aa-4b3f-a1aa-2facdbec3f9d",
          "label": "Circle Forms",
          "type": "text",
          "value": "",
          "description": "Circle of the Moon: while in Wild Shape you can use a Magic action to expend a spell slot and regain 1d8 HP per slot level; your beast forms may have higher CR. (See the subclass table for the CR cap.)"
        },
        {
          "id": "a968b01e-f03d-4f86-9bc6-4275eecfea29",
          "label": "Wild Resurgence",
          "type": "text",
          "value": "",
          "description": "Once per turn, if you have no Wild Shape uses left, expend a spell slot to regain one (no action). Also, once per Long Rest, expend a Wild Shape use to gain a level 1 spell slot."
        },
        {
          "id": "077a8759-4c9e-4e3d-8071-9ac498612199",
          "label": "Improved Circle Forms",
          "type": "text",
          "value": "",
          "description": "While in Wild Shape you can use your WIS mod in place of Con for concentration and add your WIS mod to the beast form’s attack damage; you also gain the ability to spend a slot to heal in beast form."
        },
        {
          "id": "52aa6b0f-45ca-414a-ab14-e3cab6d75323",
          "label": "Elemental Fury — Primal Strike",
          "type": "text",
          "value": "",
          "description": "Once on each of your turns when you hit with an attack roll (including in Wild Shape), deal an extra 1d8 damage of the attack’s type."
        },
        {
          "id": "b32ec58b-193e-4b3a-aaa4-1e2bb7687004",
          "label": "Moonlight Step (4/Long)",
          "type": "text",
          "value": "",
          "description": "Circle of the Moon: Bonus Action to teleport up to 30 ft to a space you can see; you have Advantage on your next attack this turn. WIS-mod uses per Long Rest; regain uses by expending a level 2+ slot."
        },
        {
          "id": "1410e0b3-127c-4e6f-87d1-a1efd02906d1",
          "label": "Spellcasting",
          "type": "text",
          "value": "",
          "description": "Wisdom-based druid casting. Prepare spells from the whole Druid list; swap after a Long Rest. Save DC 15, spell attack +7."
        },
        {
          "id": "e6e1eff7-609d-4dfa-b919-edce2e062655",
          "label": "War Caster (feat)",
          "type": "text",
          "value": "",
          "description": "Advantage on CON saves to maintain Concentration; cast somatic spells with hands full; cast a spell (1 action, single target) as an opportunity attack."
        },
        {
          "id": "b7d94963-cd8b-498e-a917-977af69404f5",
          "label": "Magic Initiate — Wizard (feat)",
          "type": "text",
          "value": "",
          "description": "Two wizard cantrips (Minor Illusion, Booming Blade) and a level 1 wizard spell (Shield) you can cast free 1/Long Rest or with slots."
        },
        {
          "id": "b3933bb0-3872-47ec-97cf-b618b45f8062",
          "label": "Homebrew feats",
          "type": "text",
          "value": "",
          "description": "Campaign feats: Dark Bargain, Runestones, Character Threads — grant Silvery Barbs and Misty Step among other benefits."
        }
      ],
