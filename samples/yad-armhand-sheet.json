      "scale": 1,
      "fields": [
        {
          "id": "26b7f3dc-bd1b-4f23-8afc-8ed43ef0de46",
          "label": "Fisticuffs",
          "type": "text",
          "value": "",
          "description": "Unarmed/Pugilist-weapon damage die is d10; bonus-action Unarmed Strike. Improved Improvisation: improvised weapons count as having the Sap mastery for you (on a hit, the target has Disadvantage on its next attack before your next turn). You have no other weapon masteries."
        },
        {
          "id": "ea1b3ad2-0a12-49ad-b483-03e88030d595",
          "label": "Iron Chin",
          "type": "text",
          "value": "",
          "description": "Base AC = 12 + CON mod while in Light or no armor and no shield."
        },
        {
          "id": "6ad5f818-8039-4477-91e3-853cac02badf",
          "label": "Heavy Hitter",
          "type": "text",
          "value": "",
          "description": "On an Unarmed Strike hit: deal Damage AND your choice of Grapple or Shove."
        },
        {
          "id": "deb3569d-9b2c-47b3-843a-9b50ea0dbdef",
          "label": "Extra Attack",
          "type": "text",
          "value": "",
          "description": "Attack twice whenever you take the Attack action."
        },
        {
          "id": "d17a9d86-1f63-4850-91e8-a1b8c6771456",
          "label": "Moxie-Fueled Fists",
          "type": "text",
          "value": "",
          "description": "Unarmed/improvised damage may be Force instead of its normal type."
        },
        {
          "id": "0d886fff-034c-4122-afb7-c84b02a3d601",
          "label": "Swagger Streak (1/Short)",
          "type": "text",
          "value": "",
          "description": "On a failed STR/DEX/CON/CHA check, spend 1 Moxie and add 1d10; may turn a failure into success."
        },
        {
          "id": "0accab79-cac7-4804-9a97-b690a51ee782",
          "label": "Down But Not Out (1/Long)",
          "type": "text",
          "value": "",
          "description": "With Bloodied But Unbowed while Bloodied: +damage = CON mod + exhaustion levels for 1 min."
        },
        {
          "id": "7344c126-ce06-45c4-a70b-16f0509193ca",
          "label": "Groundwork (Squared Circle)",
          "type": "text",
          "value": "",
          "description": "Compression Lock (grappled foes take fisticuffs + STR each turn), Inescapable (1 Moxie: Disadvantage on escapes), Stop and Drop (Unarmed hit without mastery: Grapple AND Shove)."
        },
        {
          "id": "39354a97-e082-4792-9d26-3f5bae5ad4ef",
          "label": "Muscle Mass (Squared Circle)",
          "type": "text",
          "value": "",
          "description": "Expertise in Athletics (already included in the +11)."
        },
        {
          "id": "dc6ad7ea-45cb-4415-9161-4d749211e75d",
          "label": "Meat Shield (Squared Circle)",
          "type": "text",
          "value": "",
          "description": "While grappling: Half Cover vs others. Reaction + 1 Moxie: redirect a creature’s miss onto a creature you are Grappling."
        },
        {
          "id": "683842ea-f531-4cc8-b531-72c4dc97ced1",
          "label": "Giant Ancestry — Hill’s Tumble",
          "type": "text",
          "value": "",
          "description": "On a hit that damages a Large-or-smaller creature: knock it Prone. Uses = proficiency (3) per Long Rest."
        },
        {
          "id": "e5121b21-83a5-4283-9181-6304fdce7fce",
          "label": "Large Form (1/Long)",
          "type": "text",
          "value": "",
          "description": "Bonus Action: become Large for 10 min — Advantage on STR checks, +10 ft Speed."
        },
        {
          "id": "a9ec46f9-3839-4b25-9f41-fb1daa21374e",
          "label": "Powerful Build",
          "type": "text",
          "value": "",
          "description": "Advantage on checks to end the Grappled condition; count as one size larger for carrying capacity."
