      "fields": [
        {
          "id": "a433f816-f9bb-4d3e-854b-dd21b3df8a21",
          "label": "Unarmed Strike",
          "type": "text",
          "value": "",
          "description": "Fisticuffs die d10. Moxie-Fueled Fists: may deal Force instead. Heavy Hitter: also Grapple or Shove on a hit. Hill’s Tumble: knock a Large-or-smaller target Prone (3/Long).",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod}",
            "type": "bludgeoning",
            "range": "5 ft"
          }
        },
        {
          "id": "303a8e80-17da-438f-a267-094a8577cdc9",
          "label": "Flame Tongue Handaxe",
          "type": "text",
          "value": "",
          "description": "Uses the d10 fisticuffs die. Ignite as a Bonus Action (toggle “Flame Tongue” in Conditions) to add 2d6 fire.",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod}",
            "type": "slashing",
            "extra": "2d6",
            "extraType": "fire",
            "extraWhen": "flame_tongue",
            "range": "20/60"
          }
        },
        {
          "id": "1dde7aca-5aa2-43c0-88e2-59190229cccc",
          "label": "Javelin",
          "type": "text",
          "value": "",
          "description": "Thrown weapon (uses the d10 fisticuffs die).",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod}",
            "type": "piercing",
            "range": "30/120"
          }
        },
        {
          "id": "8002f5bd-49ac-412e-b4f5-ae11d680bd07",
          "label": "Compression Lock",
