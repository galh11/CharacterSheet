        },
        {
          "id": "5a2fabb3-6bd0-4edb-91ee-fdec77c69da4",
          "label": "Meat Shield (Squared Circle)",
          "type": "text",
          "value": "",
          "description": "While grappling: Half Cover vs others. Reaction + 1 Moxie: redirect a creature’s miss onto a creature you are Grappling."
        },
        {
          "id": "5d93d4ad-bb84-4bec-ba88-316af57d0365",
