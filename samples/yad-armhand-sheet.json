    {
      "id": "5f5b36b3-f75c-44e0-92fd-e6173d86cb3c",
      "title": "Attacks",
      "description": "",
      "accent": "#f59e0b",
      "kind": "actions",
      "scale": 1,
      "fields": [
        {
          "id": "d0aa3bad-724c-4a49-a7d4-7569fecc26da",
          "label": "Unarmed Strike",
          "type": "text",
          "value": "",
          "description": "Fisticuffs die d10. Moxie-Fueled Fists: may deal Force instead. Heavy Hitter: also Grapple or Shove on a hit. Hill’s Tumble: knock a Large-or-smaller target Prone (3/Long).",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod + down_but_not_out * (con_mod + exhaustion)}",
            "type": "bludgeoning",
            "range": "5 ft"
          }
        },
        {
          "id": "a14a9e22-4419-45b0-a14c-fa66d1ca3600",
          "label": "Flame Tongue Handaxe",
          "type": "text",
          "value": "",
          "description": "Uses the d10 fisticuffs die. Ignite as a Bonus Action with the 🔥 Flame Tongue toggle to add 2d6 fire.",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod + down_but_not_out * (con_mod + exhaustion)}",
            "type": "slashing",
            "range": "20/60"
          },
          "toggles": [
            {
              "id": "e764e511-96a7-4469-b003-112e2a2819c2",
              "label": "Flame Tongue",
              "active": false,
              "field": "flame_tongue",
              "hitMode": "add",
              "hit": "",
              "parts": [
                {
                  "mode": "add",
                  "damage": "2d6",
                  "type": "fire"
                }
              ],
              "setType": "",
              "description": "Ignite as a Bonus Action: +2d6 fire on hits; sheds Bright Light 40 ft. Linked to the flame_tongue state, so the Ignite bonus action flips it too."
            }
          ]
        },
        {
          "id": "0ac64914-756a-400f-b9ba-f77dfdf5010b",
          "label": "Javelin",
          "type": "text",
          "value": "",
          "description": "Thrown weapon (uses the d10 fisticuffs die).",
          "meta": {
            "hit": "+{str_mod + proficiency}",
            "damage": "1d10+{str_mod + down_but_not_out * (con_mod + exhaustion)}",
            "type": "piercing",
            "range": "30/120"
          }
        },
        {
          "id": "dc7a3b8b-1624-4f7a-a6e7-3ee470d877b9",
          "label": "Compression Lock",
          "type": "text",
          "value": "",
          "description": "Start of your turn: each creature you have Grappled takes this Bludgeoning damage.",
